<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tobias Wagner | Portfolio</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background-color: #0d1117;
            color: #c9d1d9;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
            margin: 0;
            height: 100vh;
            display: flex;
            overflow: hidden;
        }
        .bg-glow { background: radial-gradient(circle at 50% 50%, #1c1c3d 0%, #0d1117 100%); }
        .connector { width: 2px; height: 20px; background-color: #30363d; margin-left: 22px; }
        .code-font { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; }
        
        .nav-item.active .status-dot { outline: 2px solid #58a6ff; outline-offset: 2px; }
        .sub-nav-item.active { color: #58a6ff; font-weight: bold; border-left: 2px solid #58a6ff; padding-left: 10px; margin-left: -11px; }
        
        #content-area { transition: opacity 0.15s ease-in-out; }
        
        #lightbox {
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0, 0, 0, 0.95);
            z-index: 1000;
            justify-content: center;
            align-items: center;
            backdrop-filter: blur(10px);
        }
        #lightbox img {
            max-width: 90%;
            max-height: 85%;
            box-shadow: 0 0 50px rgba(0,0,0,0.8);
            border: 1px solid #30363d;
        }

        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #0d1117; }
        ::-webkit-scrollbar-thumb { background: #30363d; border-radius: 4px; }
    </style>
</head>
<body class="bg-glow">

    <!-- Lightbox für die Großansicht -->
    <div id="lightbox" onclick="closeLightbox()">
        <span class="absolute top-5 right-10 text-white text-4xl cursor-pointer hover:text-[#58a6ff] transition-colors">&times;</span>
        <img id="lightbox-img" src="" alt="Vollbildansicht">
    </div>

    <!-- Sidebar Navigation -->
    <aside class="w-72 border-r border-[#30363d] bg-[#0d1117]/80 backdrop-blur-md flex flex-col p-6 overflow-y-auto shrink-0">
        <div class="mb-10">
            <h1 class="text-white text-xl font-bold tracking-tight">Tobias Wagner</h1>
            <p class="text-[#484f58] text-xs font-mono mt-1">main-portfolio</p>
        </div>

        <nav id="sidebar-nav">
            <!-- Sektion: Fotografie (Haken entfernt) -->
            <div class="relative">
                <div id="nav-fotografie-parent" class="nav-item bg-[#21262d] p-3 rounded-lg border border-[#30363d] transition-all shadow-md">
                    <div class="flex items-center gap-3 text-sm mb-3">
                        <span class="font-medium text-white">Fotografie</span>
                    </div>
                    <div class="pl-4 space-y-2 border-l border-[#30363d] ml-2 text-[#8b949e]">
                        <div onclick="showPage('foto-2016')" class="sub-nav-item text-xs cursor-pointer hover:text-white" id="nav-foto-2016">Archiv 2016</div>
                        <div onclick="showPage('foto-2017')" class="sub-nav-item text-xs cursor-pointer hover:text-white" id="nav-foto-2017">Archiv 2017</div>
                        <div onclick="showPage('foto-2018')" class="sub-nav-item text-xs cursor-pointer hover:text-white" id="nav-foto-2018">Archiv 2018</div>
                    </div>
                </div>
            </div>

            <div class="connector"></div>
            <div onclick="showPage('empfehlung')" class="nav-item p-4 rounded-lg border border-[#30363d] cursor-pointer hover:border-[#8b949e] transition-all" id="nav-empfehlung">
                <span class="text-sm text-[#8b949e]">Empfehlung</span>
            </div>
            
            <div class="connector"></div>
            <div onclick="showPage('kontakt')" class="nav-item p-4 rounded-lg border border-[#30363d] cursor-pointer hover:border-[#8b949e] transition-all" id="nav-kontakt">
                <span class="text-sm text-[#8b949e]">Kontakt</span>
            </div>

            <div class="connector"></div>

            <!-- Sektion: Lizenz -->
            <div class="relative pt-2">
                <div id="nav-lizenz-parent" class="nav-item bg-[#161b22]/50 p-4 rounded-lg border border-[#30363d] transition-all">
                    <span class="text-[#d29922] text-sm block mb-3">Lizenz</span>
                    <div class="pl-4 space-y-2 border-l border-[#30363d] ml-2 text-[#8b949e]">
                        <div onclick="showPage('lizenz-de')" class="sub-nav-item text-xs cursor-pointer hover:text-white" id="nav-lizenz-de">DE - Deutsch</div>
                        <div onclick="showPage('lizenz-en')" class="sub-nav-item text-xs cursor-pointer hover:text-white" id="nav-lizenz-en">EN - English</div>
                    </div>
                </div>
            </div>
        </nav>
    </aside>

    <main class="flex-1 overflow-y-auto p-8 lg:p-12 flex justify-center">
        <div id="content-area" class="w-full max-w-5xl"></div>
    </main>

    <script>
        /****************************************************************
         * 1. DEINE BILDER-DATEN
         ****************************************************************/
        
        const imageData2017 = [
            { 
                id: '20170514-001',      
                title: 'Aufnahme 001',   
                desc: 'Beschreibung hier einfügen.', 
                mm: '35mm',              
                f: '2.8',                
                s: '1/4000s',            
                iso: '100'               
            },
            { 
                id: '20170514-003', 
                title: 'Aufnahme 003', 
                desc: 'Beschreibung hier einfügen.', 
                mm: '50mm', 
                f: '4.0', 
                s: '1/60s', 
                iso: '400' 
            },
            { 
                id: '20170514-005', 
                title: 'Aufnahme 005', 
                desc: 'Beschreibung hier einfügen.', 
                mm: '24mm', 
                f: '8.0', 
                s: '1/500s', 
                iso: '200' 
            }
        ];

        /****************************************************************
         * 2. LOGIK FÜR DIE ANZEIGE & NAVIGATION
         ****************************************************************/

        function openLightbox(src) {
            const img = document.getElementById('lightbox-img');
            img.src = src;
            document.getElementById('lightbox').style.display = 'flex';
        }

        function closeLightbox() {
            document.getElementById('lightbox').style.display = 'none';
        }

        const pages = {
            'foto-2016': `<div class="p-8 border border-[#30363d] rounded-xl bg-[#0d1117] shadow-2xl"><h2 class="text-3xl font-bold text-white mb-2">Archiv 2016</h2><p class="text-[#8b949e]">Noch keine Bilder vorhanden.</p></div>`,
            
            'foto-2017': `
                <div class="space-y-8">
                    <div class="border border-[#30363d] rounded-xl bg-[#0d1117] p-8 shadow-2xl">
                        <h2 class="text-3xl font-bold text-white mb-2">Portfolio 2017</h2>
                        <p class="text-[#8b949e]">Auswahl technischer Aufnahmen.</p>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                        ${imageData2017.map(img => `
                            <div class="border border-[#30363d] rounded-xl bg-[#161b22] overflow-hidden flex flex-col group hover:border-[#58a6ff] transition-all shadow-lg">
                                <div class="cursor-pointer overflow-hidden aspect-square bg-black" onclick="openLightbox('2017/${img.id}.jpg')">
                                    <img src="2017/${img.id}.jpg" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                                </div>
                                <div class="p-5 flex flex-col flex-1">
                                    <h3 class="text-white font-bold mb-1">${img.title}</h3>
                                    <p class="text-xs text-[#8b949e] mb-4 flex-1">${img.desc}</p>
                                    <div class="grid grid-cols-2 gap-2 pt-4 border-t border-[#30363d]">
                                        <div class="flex flex-col"><span class="text-[9px] text-[#484f58] font-bold uppercase tracking-wider">Brennweite</span><span class="text-xs font-mono">${img.mm}</span></div>
                                        <div class="flex flex-col"><span class="text-[9px] text-[#484f58] font-bold uppercase tracking-wider">Blende</span><span class="text-xs font-mono">f/${img.f}</span></div>
                                        <div class="flex flex-col"><span class="text-[9px] text-[#484f58] font-bold uppercase tracking-wider">Zeit</span><span class="text-xs font-mono">${img.s}</span></div>
                                        <div class="flex flex-col"><span class="text-[9px] text-[#484f58] font-bold uppercase tracking-wider">ISO</span><span class="text-xs font-mono">${img.iso}</span></div>
                                    </div>
                                </div>
                            </div>
                        `).join('')}
                    </div>
                </div>`,

            'foto-2018': `<div class="p-8 border border-[#30363d] rounded-xl bg-[#0d1117] shadow-2xl"><h2 class="text-3xl font-bold text-white mb-2">Archiv 2018</h2><p class="text-[#8b949e]">Noch keine Bilder vorhanden.</p></div>`,
            
            'lizenz-de': `
                <div class="border border-[#30363d] rounded-xl bg-[#0d1117] overflow-hidden shadow-2xl">
                    <div class="bg-[#161b22]/40 p-4 border-b border-[#30363d] flex items-center justify-between">
                        <div class="flex items-center gap-2">
                            <span class="px-2 py-0.5 rounded bg-[#d29922]/10 text-[#d29922] text-[10px] font-bold tracking-widest uppercase">Lizenz</span>
                            <span class="text-xs text-[#8b949e]">CC BY-NC-ND 2.0 DE</span>
                        </div>
                        <a href="https://creativecommons.org/licenses/by-nc-nd/2.0/de/" target="_blank" class="text-xs text-[#58a6ff] hover:underline">Offizielle Seite</a>
                    </div>
                    <div class="p-8 text-sm">
                        <h2 class="text-2xl font-bold text-white mb-4">Creative Commons Lizenzvertrag</h2>
                        <p class="mb-6 leading-relaxed">Diese Bilder stehen unter der Lizenz <strong>Namensnennung - Nicht kommerziell - Keine Bearbeitungen 2.0 Deutschland</strong>.</p>
                        <div class="code-font leading-relaxed p-6 bg-[#010409] border border-[#30363d] rounded text-[#8b949e] space-y-4">
                            <p class="text-white font-bold">Sie dürfen:</p>
                            <p><strong>Teilen</strong> — das Material vervielfältigen und weiterverbreiten.</p>
                            <hr class="border-[#30363d]">
                            <p class="text-white font-bold">Unter folgenden Bedingungen:</p>
                            <p><strong>Namensnennung</strong> — Sie müssen angemessene Urheberangaben machen.</p>
                            <p><strong>Nicht kommerziell</strong> — Keine Nutzung für kommerzielle Zwecke.</p>
                            <p><strong>Keine Bearbeitungen</strong> — Keine Verbreitung von veränderten Fassungen.</p>
                        </div>
                        <div class="mt-8 pt-6 border-t border-[#30363d]">
                            <div class="p-4 bg-[#161b22]/30 rounded border border-[#30363d]/50">
                                <p class="text-xs text-[#8b949e]">Ich mache mir Links und Inhalte anderer Seiten nicht zu eigen. Sie werden von mir nicht täglich kontrolliert und stehen unter einer anderen Lizenz.</p>
                            </div>
                        </div>
                    </div>
                </div>`,

            'lizenz-en': `
                <div class="border border-[#30363d] rounded-xl bg-[#0d1117] overflow-hidden shadow-2xl">
                    <div class="bg-[#161b22]/40 p-4 border-b border-[#30363d] flex items-center justify-between">
                        <div class="flex items-center gap-2">
                            <span class="px-2 py-0.5 rounded bg-[#d29922]/10 text-[#d29922] text-[10px] font-bold tracking-widest uppercase">License</span>
                            <span class="text-xs text-[#8b949e]">CC BY-NC-ND 2.0 DE</span>
                        </div>
                        <a href="https://creativecommons.org/licenses/by-nc-nd/2.0/de/deed.en" target="_blank" class="text-xs text-[#58a6ff] hover:underline">Official Page</a>
                    </div>
                    <div class="p-8 text-sm">
                        <h2 class="text-2xl font-bold text-white mb-4">Creative Commons License Deed</h2>
                        <p class="mb-6 leading-relaxed italic">All images are licensed under the Attribution-NonCommercial-NoDerivs 2.0 Germany license.</p>
                        <div class="code-font leading-relaxed p-6 bg-[#010409] border border-[#30363d] rounded text-[#8b949e] space-y-4">
                            <p class="text-white font-bold">You are free to:</p>
                            <p><strong>Share</strong> — copy and redistribute the material in any medium or format.</p>
                            <hr class="border-[#30363d]">
                            <p class="text-white font-bold">Under the following terms:</p>
                            <p><strong>Attribution</strong> — You must give appropriate credit.</p>
                            <p><strong>Non-Commercial</strong> — You may not use the material for commercial purposes.</p>
                            <p><strong>NoDerivatives</strong> — If you remix, transform, or build upon the material, you may not distribute the modified material.</p>
                        </div>
                        <div class="mt-8 pt-6 border-t border-[#30363d]">
                            <div class="p-4 bg-[#161b22]/30 rounded border border-[#30363d]/50">
                                <p class="text-xs text-[#8b949e]">I do not adopt the links and contents of other pages as my own. They are not monitored daily and are subject to different licensing terms.</p>
                            </div>
                        </div>
                    </div>
                </div>`,

            'empfehlung': `<div class="p-8 border border-[#30363d] rounded-xl bg-[#0d1117] shadow-2xl"><h2 class="text-3xl font-bold text-white">Empfehlungen</h2><p class="text-[#8b949e]">Inhalt folgt.</p></div>`,
            'kontakt': `<div class="p-8 border border-[#30363d] rounded-xl bg-[#0d1117] shadow-2xl"><h2 class="text-3xl font-bold text-white">Kontakt</h2><p class="text-[#8b949e]">Schreiben Sie mir gerne eine Nachricht.</p></div>`
        };

        function showPage(pageId) {
            const contentArea = document.getElementById('content-area');
            contentArea.style.opacity = 0;
            setTimeout(() => {
                contentArea.innerHTML = pages[pageId];
                contentArea.style.opacity = 1;
            }, 150);

            document.querySelectorAll('.nav-item, .sub-nav-item').forEach(item => item.classList.remove('active'));
            if (pageId.startsWith('foto')) {
                document.getElementById('nav-fotografie-parent').classList.add('active');
                document.getElementById('nav-' + pageId).classList.add('active');
            } else if (pageId.startsWith('lizenz')) {
                document.getElementById('nav-lizenz-parent').classList.add('active');
                document.getElementById('nav-' + pageId).classList.add('active');
            } else {
                document.getElementById('nav-' + pageId).classList.add('active');
            }
        }

        showPage('foto-2017');
    </script>
</body>
</html>